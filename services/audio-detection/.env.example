# Song Chords Audio Detection - Environment Configuration
# Copy to .env and adjust values for your environment.
# Default values below assume the shared Docker Compose network.
# For host-local execution, override service hostnames with localhost values.

# --- RabbitMQ Configuration ---
# Hostname of the RabbitMQ message broker (matches service name in docker-compose)
RABBITMQ_HOST=rabbitmq
# AMQP protocol port
RABBITMQ_PORT=5672
# Queue name for audio analysis job messages
RABBITMQ_QUEUE_NAME=audio-analysis-queue
# RabbitMQ credentials (must match RABBITMQ_DEFAULT_USER/RABBITMQ_DEFAULT_PASS in docker-compose)
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123

# --- AWS / LocalStack Configuration ---
# S3-compatible endpoint URL (LocalStack for local dev, AWS for production)
AWS_ENDPOINT_URL=http://localstack:4566
# AWS credentials (LocalStack accepts arbitrary values; use real keys for production)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# AWS region for S3 operations
AWS_REGION=us-east-1
# S3 bucket name for storing input audio and intermediate artifacts
S3_BUCKET_NAME=audio-analysis-files

# --- Web API Configuration ---
# Base URL of the web-app backend where analysis results and artifacts are posted
WEB_APP_HOST=http://web-app:3000

# --- Feature flags ---
# Boolean flags use "true"/"false" (case-insensitive).
# Flags that default-on can be disabled with "false". Flags that default-off can be enabled with "true".

# Run Demucs stem separation (vocals, drums, bass, other) and upload stems to S3.
# Automatically enabled when chord_mode=no_vocals or debug_chord_diff=true or midi generation is on.
ENABLE_STEM_SEPARATION=true

# Generate MIDI from stems (implicitly enables stem separation).
ENABLE_MIDI_GENERATION=true

# Which audio mix to run chord detection on.
#   "full_mix" (or empty) — use the full audio mix (default)
#   "no_vocals" — use accompaniment-only (drums+bass+other) audio; implicitly enables stem separation
CHORD_MODE=

# Run chord detection on both full mix and no-vocals, then write text diffs to /app/output.
# Implicitly enables stem separation.
DEBUG_CHORD_DIFF=true

# Write generated .mid files to /app/output instead of just uploading to S3.
# Implicitly enables MIDI generation and stem separation.
DEBUG_MIDI_TO_DISK=true

# Re-trigger sustained chords at bar boundaries in the chord MIDI.
# Keeps piano/pad voicings from decaying to silence over long held chords.
MIDI_REPLAY_CHORDS_AT_BAR=true

# Snap vocal and bass MIDI note onsets/offsets to the nearest 16th-note grid position.
MIDI_QUANTIZE=true

# Live vocal MIDI transcription backend. Options: basic_pitch, omnizart.
VOCAL_MIDI_BACKEND=basic_pitch

# Vocal transcription cleanup preset. Options: default, balanced, high_quality.
VOCAL_MIDI_PROFILE=default

# Discard transcribed vocal notes outside this inclusive MIDI pitch range.
# C2=36 through C6=84 covers a conservative full adult singing span.
VOCAL_MIDI_MIN_PITCH=36
VOCAL_MIDI_MAX_PITCH=84

# Vocal cleanup: remove short spurious notes at segment boundaries.
MIDI_CLEANUP_BOUNDARY=true

# Vocal cleanup: normalize sustain pedal / overlapping note artifacts.
MIDI_CLEANUP_SUSTAIN_NORMALIZATION=true

# Bass cleanup: remove short spurious notes at segment boundaries.
MIDI_CLEANUP_BASS_BOUNDARY=true

# Bass cleanup: normalize sustain pedal / overlapping note artifacts.
MIDI_CLEANUP_BASS_SUSTAIN_NORMALIZATION=true

# Bass cleanup: remove very short, low-velocity debris notes.
MIDI_CLEANUP_BASS_DEBRIS=true

# Constrain vocal and bass MIDI notes to the song's detected key.
# Non-diatonic notes are evaluated against a trust model (passing tones,
# neighbor tones, chord tones, etc.) and either preserved or snapped to the
# nearest diatonic pitch.
MIDI_CONSTRAIN_TO_KEY=true

# Suppress TensorFlow C++ log output (0=all, 1=warnings+, 2=errors+, 3=fatal only).
TF_CPP_MIN_LOG_LEVEL=3
