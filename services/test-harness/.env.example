# Test Harness - Environment Configuration
# Copy to .env and adjust values for your environment.
# Default values below assume the shared Docker Compose network.

# Hostname of the RabbitMQ message broker (matches service name in docker-compose)
RABBITMQ_HOST=rabbitmq
# AMQP protocol port
RABBITMQ_PORT=5672
# Queue name for audio analysis job messages (must match the audio-detection service)
RABBITMQ_QUEUE_NAME=audio-analysis-queue
# RabbitMQ credentials (must match RABBITMQ_DEFAULT_USER/RABBITMQ_DEFAULT_PASS in docker-compose)
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
